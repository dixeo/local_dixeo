<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/dixeo/db" VERSION="20260714" COMMENT="XMLDB file for Moodle local/dixeo">
  <TABLES>
    <TABLE NAME="local_dixeo_course_ai" COMMENT="Stores AI file sync configuration and status per course">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Foreign key to course.id"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether AI file sync is enabled for this course"/>
        <FIELD NAME="syncstatus" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="none" SEQUENCE="false" COMMENT="Sync status: none, syncing, synchronized, error, paused"/>
        <FIELD NAME="filestotal" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Total number of files to sync"/>
        <FIELD NAME="filescompleted" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Number of files successfully synced"/>
        <FIELD NAME="progresspercent" TYPE="int" LENGTH="3" NOTNULL="false" SEQUENCE="false" COMMENT="Sync progress percentage 0-100"/>
        <FIELD NAME="uploadbytes" TYPE="int" LENGTH="20" NOTNULL="false" SEQUENCE="false" COMMENT="Bytes uploaded in current outbound HTTP sync (multipart body)"/>
        <FIELD NAME="uploadbytestotal" TYPE="int" LENGTH="20" NOTNULL="false" SEQUENCE="false" COMMENT="Estimated total bytes for current outbound HTTP sync"/>
        <FIELD NAME="errormessage" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Last error message if status is error"/>
        <FIELD NAME="errorcount" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Number of consecutive errors for retry backoff"/>
        <FIELD NAME="lasterrorat" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp of last error"/>
        <FIELD NAME="filehash" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false" COMMENT="SHA-256 hash of sorted file manifest (contenthash+filename). Used to skip sync when files have not changed."/>
        <FIELD NAME="lastsyncstarted" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp when last sync started"/>
        <FIELD NAME="lastsynccompleted" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp when last sync completed successfully"/>
        <FIELD NAME="enabledby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="User ID who enabled sync"/>
        <FIELD NAME="enabledat" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp when sync was enabled"/>
        <FIELD NAME="disabledby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="User ID who disabled sync"/>
        <FIELD NAME="disabledat" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp when sync was disabled"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Timestamp when record was created"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Timestamp when record was last modified"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_courseid" TYPE="foreign-unique" FIELDS="courseid" REFTABLE="course" REFFIELDS="id" COMMENT="Foreign key to course table"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_syncstatus" UNIQUE="false" FIELDS="syncstatus" COMMENT="Index for filtering by sync status"/>
        <INDEX NAME="idx_enabled" UNIQUE="false" FIELDS="enabled" COMMENT="Index for filtering enabled courses"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_dixeo_jobs" COMMENT="Local binding between remote Dixeo job IDs and Moodle course/user">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="jobid" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="Remote Dixeo job UUID"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Moodle course ID (0 when unknown / pre-course)"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="User who initiated the job"/>
        <FIELD NAME="namespace" TYPE="char" LENGTH="100" NOTNULL="true" DEFAULT="default" SEQUENCE="false" COMMENT="Dixeo API namespace"/>
        <FIELD NAME="operation" TYPE="char" LENGTH="50" NOTNULL="true" DEFAULT="unknown" SEQUENCE="false" COMMENT="Logical operation type"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Unix timestamp when the binding was created"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_jobid" UNIQUE="true" FIELDS="jobid" COMMENT="Unique remote job UUID"/>
        <INDEX NAME="idx_courseid" UNIQUE="false" FIELDS="courseid" COMMENT="Lookup by course"/>
        <INDEX NAME="idx_userid" UNIQUE="false" FIELDS="userid" COMMENT="Lookup by user"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
