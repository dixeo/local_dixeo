{{!
    @template local_dixeo/credit_report

    Credit report page template with weekly usage view.

    Context variables required for this template:
    * configured - bool - Whether the API is configured.
    * error - string|null - Error message if any.
    * balance - object - Credit balance information.
    * usage - object - Weekly usage statistics.
    * chartdata - string - JSON chart data with today highlighting.
    * transactions - array - Transaction list.
    * pagination - object - Pagination data.

    Example context (json):
    {
        "configured": true,
        "balance": {
            "formatted": "9,976 credits",
            "state": "active",
            "stateclass": "success"
        },
        "usage": {
            "weektotalformatted": "24 credits",
            "weekrange": "Dec 16 - Dec 22"
        }
    }
}}
{{#error}}
    <div class="alert alert-danger" role="alert">
        {{error}}
    </div>
    {{^configured}}
        <a href="{{settingsurl}}" class="btn btn-primary">
            {{#str}}configure_api, local_dixeo{{/str}}
        </a>
    {{/configured}}
{{/error}}

{{^error}}
    {{! Balance Card }}
    <div class="card mb-4">
        <div class="card-header">
            <h4 class="mb-0">{{#str}}current_balance, local_dixeo{{/str}}</h4>
        </div>
        <div class="card-body">
            <div class="d-flex align-items-center" style="gap: 1rem;">
                <span class="h2 mb-0">{{balance.formatted}}</span>
                <span class="badge bg-{{balance.stateclass}}">
                    {{balance.statedescription}}
                </span>
            </div>
            {{#balance.isfrozen}}
                <div class="alert alert-warning mt-3 mb-0">
                    {{#str}}account_frozen_warning, local_dixeo{{/str}}
                </div>
            {{/balance.isfrozen}}
            {{#balance.issuspended}}
                <div class="alert alert-danger mt-3 mb-0">
                    {{#str}}account_suspended_warning, local_dixeo{{/str}}
                </div>
            {{/balance.issuspended}}
        </div>
    </div>

    {{! Weekly Usage Statistics Card }}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">{{#str}}usage_statistics, local_dixeo{{/str}}</h4>
            <span class="text-muted small">{{usage.weekrange}}</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="text-muted">{{#str}}week_total, local_dixeo{{/str}}</div>
                    <div class="h5">{{usage.weektotalformatted}}</div>
                </div>
            </div>

            {{#haschartdata}}
                <div class="chart-container" style="position: relative; height: 250px;">
                    <canvas id="usageChart"></canvas>
                </div>
            {{/haschartdata}}
        </div>
    </div>

    {{! Transactions Table }}
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">{{#str}}recent_transactions, local_dixeo{{/str}}</h4>
        </div>
        <div class="card-body">
            {{#hastransactions}}
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>{{#str}}date, local_dixeo{{/str}}</th>
                                <th>{{#str}}type, local_dixeo{{/str}}</th>
                                <th>{{#str}}description, local_dixeo{{/str}}</th>
                                <th class="text-end">{{#str}}amount, local_dixeo{{/str}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#transactions}}
                                <tr>
                                    <td>
                                        <span class="text-nowrap">{{createdatformatted}}</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-{{typeclass}}">{{typelabel}}</span>
                                    </td>
                                    <td>{{description}}</td>
                                    <td class="text-end">
                                        <span class="text-{{typeclass}}">
                                            {{amountsign}}{{amountformatted}}
                                        </span>
                                    </td>
                                </tr>
                            {{/transactions}}
                        </tbody>
                    </table>
                </div>

                {{#haspagination}}
                    <nav aria-label="{{#str}}pagination, local_dixeo{{/str}}">
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item {{^pagination.hasprev}}disabled{{/pagination.hasprev}}">
                                <a class="page-link" href="{{reporturl}}?offset={{pagination.prevoffset}}">
                                    {{#str}}previous{{/str}}
                                </a>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link">
                                    {{#str}}page_x_of_y, local_dixeo, {"current": "{{pagination.currentpage}}", "total": "{{pagination.totalpages}}"}{{/str}}
                                </span>
                            </li>
                            <li class="page-item {{^pagination.hasnext}}disabled{{/pagination.hasnext}}">
                                <a class="page-link" href="{{reporturl}}?offset={{pagination.nextoffset}}">
                                    {{#str}}next{{/str}}
                                </a>
                            </li>
                        </ul>
                    </nav>
                {{/haspagination}}
            {{/hastransactions}}
            {{^hastransactions}}
                <div class="alert alert-info mb-0">
                    {{#str}}no_transactions, local_dixeo{{/str}}
                </div>
            {{/hastransactions}}
        </div>
    </div>
{{/error}}

{{#haschartdata}}
{{#js}}
require(['core/chartjs'], function(Chart) {
    var ctx = document.getElementById('usageChart').getContext('2d');
    var chartData = {{{chartdata}}};

    // Create background colors array with highlight for today
    var backgroundColors = chartData.values.map(function(value, index) {
        if (chartData.todayindex === index) {
            return 'rgba(37, 99, 235, 0.8)'; // Bright blue for today
        }
        return 'rgba(148, 163, 184, 0.5)'; // Slate gray for other days
    });

    var borderColors = chartData.values.map(function(value, index) {
        if (chartData.todayindex === index) {
            return 'rgba(37, 99, 235, 1)'; // Bright blue border for today
        }
        return 'rgba(148, 163, 184, 0.8)'; // Slate gray border for other days
    });

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: chartData.labels,
            datasets: [{
                label: chartData.label,
                data: chartData.values,
                backgroundColor: backgroundColors,
                borderColor: borderColors,
                borderWidth: 2,
                borderRadius: 6,
                borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.raw.toLocaleString() + ' credits';
                        },
                        title: function(context) {
                            var fullLabel = chartData.fulllabels[context[0].dataIndex];
                            if (chartData.todayindex === context[0].dataIndex) {
                                return fullLabel + ' (Today)';
                            }
                            return fullLabel;
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(148, 163, 184, 0.1)'
                    },
                    ticks: {
                        callback: function(value) {
                            return value.toLocaleString();
                        }
                    }
                },
                x: {
                    grid: {
                        display: false
                    }
                }
            }
        }
    });
});
{{/js}}
{{/haschartdata}}
